{
  "name": "@ecosy/googleapis",
  "version": "0.1.0",
  "description": "Google APIs client (Drive, Auth, JWT) built on @ecosy/core Http",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./services/drive": {
      "source": "./src/services/drive.ts",
      "types": "./dist/services/drive.d.ts",
      "import": "./dist/services/drive.mjs",
      "require": "./dist/services/drive.js"
    },
    "./services/auth": {
      "source": "./src/services/auth.ts",
      "types": "./dist/services/auth.d.ts",
      "import": "./dist/services/auth.mjs",
      "require": "./dist/services/auth.js"
    },
    "./lib/jwt": {
      "source": "./src/lib/jwt.ts",
      "types": "./dist/lib/jwt.d.ts",
      "import": "./dist/lib/jwt.mjs",
      "require": "./dist/lib/jwt.js"
    },
    "./types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "eslint src/ && rollup -c",
    "prepublishOnly": "yarn clean && yarn build",
    "dev": "rollup -c --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/material-atomic/ecosy-googleapis.git"
  },
  "keywords": [
    "ecosy",
    "googleapis",
    "google-drive",
    "google-auth",
    "jwt",
    "typescript"
  ],
  "author": "material-atomic",
  "dependencies": {
    "@ecosy/core": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "glob": "^13.0.6",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.1",
    "typescript": "^6.0.2"
  }
}
